# ==============================================================================
# Themida — Environment Variables
# Copy this file to .env.local for local development. NEVER commit .env.local.
# ==============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Supabase ---
# Public — exposed to the browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret — server only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=

# --- GitHub OAuth App ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Trigger.dev ---
TRIGGER_SECRET_KEY=

# --- Resend (email) ---
RESEND_API_KEY=

# --- Encryption ---
# 32-byte (64 hex) key used to encrypt GitHub tokens at rest.
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=
