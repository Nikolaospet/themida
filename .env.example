# ==============================================================================
# Themida — Environment Variables
# Copy this file to .env.local for local development. NEVER commit .env.local.
# ==============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Supabase ---
# Public — exposed to the browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret — server only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------------------------
# LLM provider
# ------------------------------------------------------------------------------
# Pick one provider. The scanner is provider-agnostic — only the values for
# the provider you choose need to be set; the others can stay empty.
#
#   LLM_PROVIDER=anthropic   -> Anthropic Messages API
#   LLM_PROVIDER=openai      -> any Chat-Completions-shaped endpoint
#                               (OpenAI, OpenRouter, Groq, Together,
#                                vLLM, llama.cpp server, Ollama, LiteLLM, …)
LLM_PROVIDER=anthropic

# --- Anthropic (when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI-compatible (when LLM_PROVIDER=openai) ---
OPENAI_API_KEY=
# Base URL of the provider — defaults to OpenAI itself when blank.
# Examples:
#   https://api.openai.com/v1
#   https://openrouter.ai/api/v1
#   https://api.groq.com/openai/v1
#   https://api.together.xyz/v1
#   http://localhost:8000/v1            # vLLM / llama.cpp server / LiteLLM
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini
# Header carrying the provider's request id. Most providers match OpenAI;
# override if yours uses a different spelling.
OPENAI_REQUEST_ID_HEADER=x-request-id
# Label written to llm_api_calls.provider in the DB. Override to
# distinguish backends, e.g. "openrouter", "groq", "vllm-local".
OPENAI_PROVIDER_LABEL=openai

# --- GitHub OAuth App ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- GitHub App (Themida-installed-on-repos) ---
# Created via docs/setup/github-app.md.
GITHUB_APP_ID=
GITHUB_APP_SLUG=
# Multi-line PEM. Preserve newlines — wrap in double quotes if the
# host requires single-line values, then convert literal \n at runtime.
GITHUB_APP_PRIVATE_KEY=
# 32-byte hex secret used to HMAC-sign the install state token.
# Generate with: openssl rand -hex 32
GITHUB_APP_INSTALL_STATE_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Trigger.dev ---
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=proj_xxxxxxxxxx

# --- Resend (email) ---
RESEND_API_KEY=

# --- Encryption ---
# 32-byte (64 hex) key used to encrypt GitHub tokens at rest.
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# --- Sentry (errors / traces) ---
# Public DSN — sent to Sentry from both browser and server.
NEXT_PUBLIC_SENTRY_DSN=
# Environment label shown in Sentry UI: "development" | "preview" | "production"
SENTRY_ENVIRONMENT=development
# Server-only auth token used during build to upload source maps.
SENTRY_AUTH_TOKEN=
# Sentry organisation slug + project (used for source-map upload at build time)
SENTRY_ORG=
SENTRY_PROJECT=themida
